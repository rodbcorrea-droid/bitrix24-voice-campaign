# ============================================================
# Bitrix24 Voice Campaign — Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Server ---
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# --- Bitrix24 CRM ---
# Option 1: Webhook URL (REST API direct access)
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.com/rest/1/your-webhook-token/
# Option 2: OAuth (for advanced features)
BITRIX24_OAUTH_CLIENT_ID=
BITRIX24_OAUTH_CLIENT_SECRET=
BITRIX24_OAUTH_ACCESS_TOKEN=
BITRIX24_OAUTH_REFRESH_TOKEN=

# --- Telephony Provider ---
# Options: bitrix24 | twilio | sip
TELEPHONY_PROVIDER=twilio

# Twilio Configuration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WEBSOCKET_URL=wss://your-server.com/media-stream

# SIP Configuration (alternative)
SIP_HOST=
SIP_PORT=5060
SIP_USERNAME=
SIP_PASSWORD=

# --- Voice AI ---
# Speech-to-Text
STT_PROVIDER=deepgram
STT_API_KEY=
STT_MODEL=nova-2
STT_LANGUAGE=pt-BR

# LLM (Language Model)
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=500
LLM_SYSTEM_PROMPT_PATH=config/prompts/agent-system.txt

# Text-to-Speech
TTS_PROVIDER=elevenlabs
TTS_API_KEY=
TTS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
TTS_MODEL=eleven_multilingual_v2

# --- Campaign Defaults ---
CAMPAIGN_DEFAULT_TIMEZONE=America/Sao_Paulo
CAMPAIGN_DEFAULT_START_HOUR=9
CAMPAIGN_DEFAULT_END_HOUR=18
CAMPAIGN_DEFAULT_MAX_CONCURRENT=10
CAMPAIGN_DEFAULT_RATE_PER_MINUTE=5
CAMPAIGN_DEFAULT_MAX_ATTEMPTS=3

# --- Compliance ---
COMPLIANCE_LGPD_ENABLED=true
COMPLIANCE_DND_HOURS_START=21
COMPLIANCE_DND_HOURS_END=8
COMPLIANCE_MAX_CALLS_PER_CONTACT=3
COMPLIANCE_OPT_OUT_CHECK=true

# --- Database ---
DB_PATH=data/campaign.db

# --- Dashboard ---
DASHBOARD_ENABLED=true
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-in-production
